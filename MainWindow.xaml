<Window x:Class="Subtitle_draft_GMTPC.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Subtitle_draft_GMTPC"
        mc:Ignorable="d"
        Title="Subtitle draft GMTPC - Phụ đề .SRT / .ASS"
        Height="800" Width="900"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E1E"
        Foreground="#E0E0E0"
        MinWidth="1000" MinHeight="600"
        Loaded="MainWindow_Loaded">

    <Window.Resources>
        <!-- Style cho Button theo Windows 11 Dark -->
        <Style x:Key="AccentButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#0078D4"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#0078D4"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1A86D9"/>
                    <Setter Property="BorderBrush" Value="#1A86D9"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#006CBE"/>
                    <Setter Property="BorderBrush" Value="#006CBE"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Style cho Button Donate (vàng) -->
        <Style x:Key="DonateButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#D4A017"/>
            <Setter Property="Foreground" Value="#000000"/>
            <Setter Property="BorderBrush" Value="#D4A017"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E8B51A"/>
                    <Setter Property="BorderBrush" Value="#E8B51A"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#C4900E"/>
                    <Setter Property="BorderBrush" Value="#C4900E"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Style cho ToggleButton theo Windows 11 Dark -->
        <Style x:Key="ToggleWordWrapStyle" TargetType="ToggleButton">
            <Setter Property="Background" Value="#0078D4"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#0078D4"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1A86D9"/>
                    <Setter Property="BorderBrush" Value="#1A86D9"/>
                </Trigger>
                <Trigger Property="IsChecked" Value="True">
                    <Setter Property="Background" Value="#0078D4"/>
                    <Setter Property="BorderBrush" Value="#0078D4"/>
                </Trigger>
                <Trigger Property="IsChecked" Value="False">
                    <Setter Property="Background" Value="#505050"/>
                    <Setter Property="BorderBrush" Value="#505050"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Style cho TextBox theo Windows 11 Dark -->
        <Style x:Key="DarkTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="#2D2D2D"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="BorderBrush" Value="#404040"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontFamily" Value="Consolas, Courier New"/>
            <Setter Property="AcceptsReturn" Value="True"/>
            <Setter Property="AcceptsTab" Value="True"/>
            <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="HorizontalScrollBarVisibility" Value="Auto"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalScrollBarVisibility="{TemplateBinding VerticalScrollBarVisibility}"
                                          HorizontalScrollBarVisibility="{TemplateBinding HorizontalScrollBarVisibility}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Style cho Label -->
        <Style x:Key="SectionLabelStyle" TargetType="Label">
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <!-- Style cho Border của mỗi panel -->
        <Style x:Key="PanelBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="#252526"/>
            <Setter Property="BorderBrush" Value="#3E3E42"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="Margin" Value="6"/>
        </Style>

        <!-- Style cho Toast notification -->
        <Style x:Key="ToastBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="#323232"/>
            <Setter Property="BorderBrush" Value="#0078D4"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#000000" Direction="270" ShadowDepth="4"
                                      Opacity="0.5" BlurRadius="8"/>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Search Panel (Ctrl+F to toggle) -->
        <Border x:Name="SearchPanel" Grid.Row="0" Background="#252526" BorderBrush="#0078D4" 
                BorderThickness="0,0,0,1" Padding="8,4" Visibility="Collapsed">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <TextBlock Text="🔍 Tìm kiếm:" Foreground="#E0E0E0" FontSize="12" 
                           VerticalAlignment="Center" Margin="0,0,6,0"/>
                <TextBox x:Name="TxtSearchBox" Width="300" Height="24" FontSize="12" 
                         Background="#2D2D2D" Foreground="#E0E0E0" BorderBrush="#404040"
                         BorderThickness="1" Padding="6,2"
                         KeyDown="TxtSearchBox_KeyDown"
                         TextChanged="TxtSearchBox_TextChanged"/>
                <Button x:Name="BtnSearchPrev" Content="◀ Prev" 
                        Style="{StaticResource AccentButtonStyle}"
                        Padding="10,3" FontSize="11" Margin="6,0,0,0"
                        Click="BtnSearchPrev_Click"/>
                <Button x:Name="BtnSearchNext" Content="Next ▶" 
                        Style="{StaticResource AccentButtonStyle}"
                        Padding="10,3" FontSize="11" Margin="4,0,0,0"
                        Click="BtnSearchNext_Click"/>
                <Button x:Name="BtnSearchClose" Content="✕" 
                        Style="{StaticResource AccentButtonStyle}"
                        Padding="8,3" FontSize="12" Margin="4,0,0,0"
                        Background="#D40000" BorderBrush="#D40000"
                        Click="BtnSearchClose_Click"/>
                <TextBlock x:Name="TxtSearchStatus" Text="" Foreground="#808080" 
                           FontSize="11" VerticalAlignment="Center" Margin="8,0,0,0"/>
            </StackPanel>
        </Border>

        <!-- Toolbar: Word Wrap toggle + Donate -->
        <Border Grid.Row="1" Background="#252526" BorderBrush="#3E3E42" BorderThickness="0,0,0,1" Padding="12,6">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <TextBlock Text="📝 Word Wrap:" Foreground="#E0E0E0" FontSize="12" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <ToggleButton x:Name="ToggleWordWrap" Content="ON"
                              Style="{StaticResource ToggleWordWrapStyle}"
                              Padding="16,4" FontSize="12"
                              IsChecked="True" Click="ToggleWordWrap_Click"
                              Margin="0,0,12,0"/>
                <Button x:Name="BtnDonateToolbar" Content="💛 Donate"
                        Style="{StaticResource DonateButtonStyle}"
                        Padding="16,4" FontSize="12"
                        Click="BtnDonate_Click"/>
            </StackPanel>
        </Border>

        <TabControl x:Name="MainTabControl" Grid.Row="2" Background="#1E1E1E" BorderBrush="#3E3E42" BorderThickness="1">
            <!-- Tab 1: Hardware Info -->
            <TabItem Header="🖥️ Hardware Info">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- PANEL 1: GPU -->
                    <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource PanelBorderStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Label Grid.Row="0" Content="🎮 GPU" Style="{StaticResource SectionLabelStyle}"/>

                            <TextBox x:Name="TxtGpuInfo" Grid.Row="1"
                                     Style="{StaticResource DarkTextBoxStyle}"
                                     IsReadOnly="True" FontSize="14"
                                     PreviewMouseWheel="TextBox_PreviewMouseWheel"/>

                            <Button x:Name="BtnCopyGpu" Grid.Row="2" Content="📋 Copy GPU"
                                    Style="{StaticResource AccentButtonStyle}"
                                    HorizontalAlignment="Right" Margin="0,8,0,0"
                                    Click="BtnCopyGpu_Click"/>
                        </Grid>
                    </Border>

                    <!-- PANEL 2: CPU -->
                    <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource PanelBorderStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Label Grid.Row="0" Content="🔧 CPU" Style="{StaticResource SectionLabelStyle}"/>

                            <TextBox x:Name="TxtCpuInfo" Grid.Row="1"
                                     Style="{StaticResource DarkTextBoxStyle}"
                                     IsReadOnly="True" FontSize="14"
                                     PreviewMouseWheel="TextBox_PreviewMouseWheel"/>

                            <Button x:Name="BtnCopyCpu" Grid.Row="2" Content="📋 Copy CPU"
                                    Style="{StaticResource AccentButtonStyle}"
                                    HorizontalAlignment="Right" Margin="0,8,0,0"
                                    Click="BtnCopyCpu_Click"/>
                        </Grid>
                    </Border>

                    <!-- PANEL 3: RAM -->
                    <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource PanelBorderStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Label Grid.Row="0" Content="💾 RAM" Style="{StaticResource SectionLabelStyle}"/>

                            <TextBox x:Name="TxtRamInfo" Grid.Row="1"
                                     Style="{StaticResource DarkTextBoxStyle}"
                                     IsReadOnly="True" FontSize="14"
                                     PreviewMouseWheel="TextBox_PreviewMouseWheel"/>

                            <Button x:Name="BtnCopyRam" Grid.Row="2" Content="📋 Copy RAM"
                                    Style="{StaticResource AccentButtonStyle}"
                                    HorizontalAlignment="Right" Margin="0,8,0,0"
                                    Click="BtnCopyRam_Click"/>
                        </Grid>
                    </Border>

                    <!-- PANEL 4: Mainboard -->
                    <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource PanelBorderStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Label Grid.Row="0" Content="🔌 Mainboard" Style="{StaticResource SectionLabelStyle}"/>

                            <TextBox x:Name="TxtMainboardInfo" Grid.Row="1"
                                     Style="{StaticResource DarkTextBoxStyle}"
                                     IsReadOnly="True" FontSize="14"
                                     PreviewMouseWheel="TextBox_PreviewMouseWheel"/>

                            <Button x:Name="BtnCopyMainboard" Grid.Row="2" Content="📋 Copy Mainboard"
                                    Style="{StaticResource AccentButtonStyle}"
                                    HorizontalAlignment="Right" Margin="0,8,0,0"
                                    Click="BtnCopyMainboard_Click"/>
                        </Grid>
                    </Border>

                    <!-- Footer: Author info -->
                    <Border Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                            Background="#1A1A1A" BorderBrush="#3E3E42" BorderThickness="0,1,0,0"
                            Padding="12,8">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="Tác giả: " Foreground="#808080" FontSize="12"/>
                            <TextBlock Text="Ma Minh Toàn 1993" Foreground="#0078D4" FontSize="12" FontWeight="SemiBold"/>
                            <TextBlock Text="  |  " Foreground="#505050" FontSize="12"/>
                            <TextBlock Text="Hardware Info GMTPC" Foreground="#808080" FontSize="12"/>
                            <TextBlock Text="  |  " Foreground="#505050" FontSize="12"/>
                            <TextBlock Text="Xem thông tin phần cứng hệ thống" Foreground="#808080" FontSize="12"/>
                        </StackPanel>
                    </Border>

                    <!-- Toast Notification -->
                    <Border x:Name="ToastBorderHardware" Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2"
                            HorizontalAlignment="Center" VerticalAlignment="Top"
                            Visibility="Collapsed" Style="{StaticResource ToastBorderStyle}"
                            Margin="0,20,0,0" MinWidth="300" MaxWidth="500">
                        <TextBlock x:Name="ToastTextHardware" Text="" Foreground="#FFFFFF" FontSize="14"
                                   TextAlignment="Center" TextWrapping="Wrap"/>
                    </Border>
                </Grid>
            </TabItem>

            <!-- Tab 2: Dialogue -->
            <TabItem Header="💬 Dialogue">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- PANEL 1: Input Subtitle -->
                    <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource PanelBorderStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Orientation="Horizontal">
                                <Label Content="📄 Input Subtitle (Paste vào đây)" Style="{StaticResource SectionLabelStyle}"/>
                                <TextBlock x:Name="TxtDialogueFormat" Text="" Foreground="#808080" FontSize="11"
                                           VerticalAlignment="Center" Margin="8,0,0,0"/>
                            </StackPanel>

                            <TextBox x:Name="TxtDialogueInput" Grid.Row="1"
                                     Style="{StaticResource DarkTextBoxStyle}"
                                     TextChanged="TxtDialogueInput_TextChanged"
                                     PreviewMouseWheel="TextBox_PreviewMouseWheel"/>
                        </Grid>
                    </Border>

                    <!-- PANEL 2: Output Dialogue (STT + Dialogue) -->
                    <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource PanelBorderStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Label Grid.Row="0" Content="🔢 Output Dialogue (Copy vào Excel)" Style="{StaticResource SectionLabelStyle}"/>

                            <TextBox x:Name="TxtDialogueOutput" Grid.Row="1"
                                     Style="{StaticResource DarkTextBoxStyle}"
                                     IsReadOnly="True"
                                     PreviewMouseWheel="TextBox_PreviewMouseWheel"/>

                            <Button x:Name="BtnCopyDialogue" Grid.Row="2" Content="📋 Copy Dialogue"
                                    Style="{StaticResource AccentButtonStyle}"
                                    HorizontalAlignment="Right" Margin="0,8,0,0"
                                    Click="BtnCopyDialogue_Click"/>
                        </Grid>
                    </Border>

                    <!-- PANEL 3: Manual Input (3 cột hoặc 3 hàng) -->
                    <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource PanelBorderStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Label Grid.Row="0" Content="✏️ Manual Input (3 cột: STT+Text gốc+Text Việt | 3 hàng: STT/Text gốc/Text Việt - Ghép Text gốc với Time Code)" Style="{StaticResource SectionLabelStyle}"/>

                            <TextBox x:Name="TxtDialogueManual" Grid.Row="1"
                                     Style="{StaticResource DarkTextBoxStyle}"
                                     TextChanged="TxtDialogueManual_TextChanged"
                                     PreviewMouseWheel="TextBox_PreviewMouseWheel"/>
                        </Grid>
                    </Border>

                    <!-- PANEL 4: Merged (Time Code Panel 1 + Text Panel 3) -->
                    <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource PanelBorderStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Label Grid.Row="0" Content="🎬 Merged (Time Code + Manual Text)" Style="{StaticResource SectionLabelStyle}"/>

                            <TextBox x:Name="TxtDialogueMerged" Grid.Row="1"
                                     Style="{StaticResource DarkTextBoxStyle}"
                                     IsReadOnly="True"
                                     PreviewMouseWheel="TextBox_PreviewMouseWheel"/>

                            <Button x:Name="BtnCopyMerged" Grid.Row="2" Content="📋 Copy Merged"
                                    Style="{StaticResource AccentButtonStyle}"
                                    HorizontalAlignment="Right" Margin="0,8,0,0"
                                    Click="BtnCopyMerged_Click"/>
                        </Grid>
                    </Border>

                    <!-- Footer: Author info -->
                    <Border Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                            Background="#1A1A1A" BorderBrush="#3E3E42" BorderThickness="0,1,0,0"
                            Padding="12,8">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="Tác giả: " Foreground="#808080" FontSize="12"/>
                            <TextBlock Text="Ma Minh Toàn 1993" Foreground="#0078D4" FontSize="12" FontWeight="SemiBold"/>
                            <TextBlock Text="  |  " Foreground="#505050" FontSize="12"/>
                            <TextBlock Text="Dialogue GMTPC" Foreground="#808080" FontSize="12"/>
                            <TextBlock Text="  |  " Foreground="#505050" FontSize="12"/>
                            <TextBlock Text="Trích xuất thoại từ phụ đề" Foreground="#808080" FontSize="12"/>
                        </StackPanel>
                    </Border>

                    <!-- Toast Notification (ẩn mặc định) -->
                    <Border x:Name="ToastBorderDialogue" Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2"
                            HorizontalAlignment="Center" VerticalAlignment="Top"
                            Visibility="Collapsed" Style="{StaticResource ToastBorderStyle}"
                            Margin="0,20,0,0" MinWidth="300" MaxWidth="500">
                        <TextBlock x:Name="ToastTextDialogue" Text="" Foreground="#FFFFFF" FontSize="14"
                                   TextAlignment="Center" TextWrapping="Wrap"/>
                    </Border>
                </Grid>
            </TabItem>

            <!-- Tab 3: Translate (AI via WebView2) -->
            <TabItem Header="🌐 Translate">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- PANEL 1: Input Subtitle -->
                    <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource PanelBorderStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Orientation="Horizontal">
                                <Label Content="📄 Input Subtitle (Paste vào đây)" Style="{StaticResource SectionLabelStyle}"/>
                                <TextBlock x:Name="TxtTranslateInputFormat" Text="" Foreground="#808080" FontSize="11"
                                           VerticalAlignment="Center" Margin="8,0,0,0"/>
                            </StackPanel>

                            <TextBox x:Name="TxtTranslateInput" Grid.Row="1"
                                     Style="{StaticResource DarkTextBoxStyle}"
                                     PreviewMouseWheel="TextBox_PreviewMouseWheel"/>
                        </Grid>
                    </Border>

                    <!-- PANEL 2: Translate Controls -->
                    <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource PanelBorderStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Buttons row -->
                            <WrapPanel Grid.Row="0" Margin="0,0,0,8" Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button x:Name="BtnOpenQwen" Content="🌐 Mở chat.qwen.ai"
                                        Style="{StaticResource AccentButtonStyle}" Padding="12,6" FontSize="12"
                                        Margin="0,0,6,0" Click="BtnOpenQwen_Click"/>
                                <Button x:Name="BtnCopyForPaste" Content="📋 Copy Prompt+Subtitle"
                                        Style="{StaticResource AccentButtonStyle}" Padding="12,6" FontSize="12"
                                        Margin="0,0,6,0" Click="BtnCopyForPaste_Click"/>
                                <Button x:Name="BtnSavePrompts" Content="💾 Save Prompts"
                                        Style="{StaticResource AccentButtonStyle}" Padding="12,6" FontSize="12"
                                        Margin="0,0,6,0" Click="BtnSavePrompts_Click"/>
                                <Button x:Name="BtnLoadPrompts" Content="📂 Load Prompts"
                                        Style="{StaticResource AccentButtonStyle}" Padding="12,6" FontSize="12"
                                        Click="BtnLoadPrompts_Click"/>
                            </WrapPanel>

                            <!-- Prompt Buttons -->
                            <StackPanel Grid.Row="1" Margin="0,0,0,8" Orientation="Horizontal" HorizontalAlignment="Left">
                                <Button x:Name="BtnPrompt1" Content="1. Prompt 1"
                                        Style="{StaticResource AccentButtonStyle}" Padding="12,6" FontSize="11"
                                        Margin="0,0,4,0" Click="BtnPrompt_Click" Tag="1"/>
                                <Button x:Name="BtnPrompt2" Content="2. Prompt 2"
                                        Style="{StaticResource AccentButtonStyle}" Padding="12,6" FontSize="11"
                                        Margin="0,0,4,0" Click="BtnPrompt_Click" Tag="2"/>
                                <Button x:Name="BtnPrompt3" Content="3. Prompt 3"
                                        Style="{StaticResource AccentButtonStyle}" Padding="12,6" FontSize="11"
                                        Margin="0,0,4,0" Click="BtnPrompt_Click" Tag="3"/>
                                <Button x:Name="BtnPrompt4" Content="4. Prompt 4"
                                        Style="{StaticResource AccentButtonStyle}" Padding="12,6" FontSize="11"
                                        Margin="0,0,4,0" Click="BtnPrompt_Click" Tag="4"/>
                                <Button x:Name="BtnPrompt5" Content="5. Prompt 5"
                                        Style="{StaticResource AccentButtonStyle}" Padding="12,6" FontSize="11"
                                        Margin="0,0,4,0" Click="BtnPrompt_Click" Tag="5"/>
                                <Button x:Name="BtnRenamePrompt" Content="✏️ Rename"
                                        Style="{StaticResource AccentButtonStyle}" Padding="10,6" FontSize="11"
                                        Margin="8,0,0,0" Click="BtnRenamePrompt_Click"/>
                            </StackPanel>

                            <!-- Prompt input (expanded) -->
                            <Grid Grid.Row="2" Margin="0,0,0,6">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Label Grid.Row="0" Content="💬 Prompt:" Style="{StaticResource SectionLabelStyle}" Padding="0"/>
                                <TextBox x:Name="TxtPrompt" Grid.Row="1" Style="{StaticResource DarkTextBoxStyle}"
                                         TextWrapping="Wrap" AcceptsReturn="True" FontSize="12" Padding="6"
                                         LostFocus="TxtPrompt_LostFocus"
                                         PreviewMouseWheel="TextBox_PreviewMouseWheel"/>
                            </Grid>

                            <!-- Status -->
