<Window x:Class="Subtitle_draft_GMTPC.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Subtitle_draft_GMTPC"
        mc:Ignorable="d"
        Title="Subtitle draft GMTPC - Phụ đề .SRT / .ASS"
        Height="800" Width="900"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E1E"
        Foreground="#E0E0E0"
        MinWidth="1000" MinHeight="600"
        Loaded="MainWindow_Loaded">

    <Window.Resources>
        <!-- Style cho Button theo Windows 11 Dark -->
        <Style x:Key="AccentButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#0078D4"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#0078D4"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1A86D9"/>
                    <Setter Property="BorderBrush" Value="#1A86D9"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#006CBE"/>
                    <Setter Property="BorderBrush" Value="#006CBE"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Style cho Button Donate (vàng) -->
        <Style x:Key="DonateButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#D4A017"/>
            <Setter Property="Foreground" Value="#000000"/>
            <Setter Property="BorderBrush" Value="#D4A017"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E8B51A"/>
                    <Setter Property="BorderBrush" Value="#E8B51A"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#C4900E"/>
                    <Setter Property="BorderBrush" Value="#C4900E"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Style cho ToggleButton theo Windows 11 Dark -->
        <Style x:Key="ToggleWordWrapStyle" TargetType="ToggleButton">
            <Setter Property="Background" Value="#0078D4"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#0078D4"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1A86D9"/>
                    <Setter Property="BorderBrush" Value="#1A86D9"/>
                </Trigger>
                <Trigger Property="IsChecked" Value="True">
                    <Setter Property="Background" Value="#0078D4"/>
                    <Setter Property="BorderBrush" Value="#0078D4"/>
                </Trigger>
                <Trigger Property="IsChecked" Value="False">
                    <Setter Property="Background" Value="#505050"/>
                    <Setter Property="BorderBrush" Value="#505050"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Switch toggle style -->
        <Style x:Key="SwitchToggleStyle" TargetType="ToggleButton">
            <Setter Property="Width" Value="54"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Grid Width="{TemplateBinding Width}" Height="{TemplateBinding Height}">
                            <Border x:Name="SwitchTrack"
                                    Width="48" Height="24"
                                    CornerRadius="12"
                                    Background="#505050"
                                    BorderBrush="#686868"
                                    BorderThickness="1"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"/>
                            <Ellipse x:Name="SwitchThumb"
                                     Width="18" Height="18"
                                     Fill="#F2F2F2"
                                     HorizontalAlignment="Left"
                                     VerticalAlignment="Center"
                                     Margin="6,0,0,0"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="SwitchTrack" Property="Background" Value="#0078D4"/>
                                <Setter TargetName="SwitchTrack" Property="BorderBrush" Value="#1A86D9"/>
                                <Setter TargetName="SwitchThumb" Property="HorizontalAlignment" Value="Right"/>
                                <Setter TargetName="SwitchThumb" Property="Margin" Value="0,0,6,0"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="SwitchTrack" Property="BorderBrush" Value="#B0B0B0"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="SwitchTrack" Property="Opacity" Value="0.45"/>
                                <Setter TargetName="SwitchThumb" Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Style cho TextBox theo Windows 11 Dark -->
        <Style x:Key="DarkTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="#2D2D2D"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="BorderBrush" Value="#404040"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontFamily" Value="Consolas, Courier New"/>
            <Setter Property="AcceptsReturn" Value="True"/>
            <Setter Property="AcceptsTab" Value="True"/>
            <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="HorizontalScrollBarVisibility" Value="Auto"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalScrollBarVisibility="{TemplateBinding VerticalScrollBarVisibility}"
                                          HorizontalScrollBarVisibility="{TemplateBinding HorizontalScrollBarVisibility}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Style cho Label -->
        <Style x:Key="SectionLabelStyle" TargetType="Label">
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <!-- Style cho Border của mỗi panel -->
        <Style x:Key="PanelBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="#252526"/>
            <Setter Property="BorderBrush" Value="#3E3E42"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="Margin" Value="6"/>
        </Style>

        <!-- Style cho Toast notification -->
        <Style x:Key="ToastBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="#323232"/>
            <Setter Property="BorderBrush" Value="#0078D4"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#000000" Direction="270" ShadowDepth="4"
                                      Opacity="0.5" BlurRadius="8"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Style cho ComboBox dark theme -->
        <Style x:Key="DarkComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Background" Value="#2D2D2D"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="BorderBrush" Value="#404040"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="4,3"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Background" Value="#2D2D2D"/>
                        <Setter Property="Foreground" Value="#E0E0E0"/>
                        <Setter Property="Padding" Value="4,3"/>
                        <Style.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter Property="Background" Value="#0078D4"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#0078D4"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ToggleButton Grid.Column="0" Grid.ColumnSpan="2"
                                          Focusable="false"
                                          IsChecked="{Binding Path=IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          ClickMode="Press">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="Border"
                                                Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="4">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="20"/>
                                                </Grid.ColumnDefinitions>
                                                <ContentPresenter Grid.Column="0"
                                                                  Margin="6,3,0,3"
                                                                  Content="{TemplateBinding Tag}"
                                                                  VerticalAlignment="Center"
                                                                  HorizontalAlignment="Left"/>
                                                <Path Grid.Column="1"
                                                      x:Name="Arrow"
                                                      Fill="#E0E0E0"
                                                      HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"
                                                      Data="M 0 0 L 4 4 L 8 0 Z"/>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Border" Property="BorderBrush" Value="#0078D4"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter Grid.Column="0"
                                              x:Name="ContentSite"
                                              IsHitTestVisible="False"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                              Margin="8,3,20,3"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Left"
                                              TextElement.Foreground="#E0E0E0"/>
                            <Popup x:Name="Popup"
                                   Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Slide">
                                <Grid x:Name="DropDown"
                                      SnapsToDevicePixels="True"
                                      MinWidth="{TemplateBinding ActualWidth}"
                                      MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <Border x:Name="DropDownBorder"
                                            Background="#2D2D2D"
                                            BorderBrush="#404040"
                                            BorderThickness="1"
                                            CornerRadius="4"/>
                                    <ScrollViewer Margin="4" SnapsToDevicePixels="True">
                                        <StackPanel IsItemsHost="True"
                                                    KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Grid>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="BorderBrush" Value="#0078D4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Search Panel (Ctrl+F to toggle) -->
        <Border x:Name="SearchPanel" Grid.Row="0" Background="#252526" BorderBrush="#0078D4" 
                BorderThickness="0,0,0,1" Padding="8,4" Visibility="Collapsed">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <TextBlock Text="🔍 Tìm kiếm:" Foreground="#E0E0E0" FontSize="12" 
                           VerticalAlignment="Center" Margin="0,0,6,0"/>
                <TextBox x:Name="TxtSearchBox" Width="300" Height="24" FontSize="12" 
                         Background="#2D2D2D" Foreground="#E0E0E0" BorderBrush="#404040"
                         BorderThickness="1" Padding="6,2"
                         KeyDown="TxtSearchBox_KeyDown"
                         TextChanged="TxtSearchBox_TextChanged"/>
                <Button x:Name="BtnSearchPrev" Content="◀ Prev" 
                        Style="{StaticResource AccentButtonStyle}"
                        Padding="10,3" FontSize="11" Margin="6,0,0,0"
                        Click="BtnSearchPrev_Click"/>
                <Button x:Name="BtnSearchNext" Content="Next ▶" 
                        Style="{StaticResource AccentButtonStyle}"
                        Padding="10,3" FontSize="11" Margin="4,0,0,0"
                        Click="BtnSearchNext_Click"/>
                <Button x:Name="BtnSearchClose" Content="✕" 
                        Style="{StaticResource AccentButtonStyle}"
                        Padding="8,3" FontSize="12" Margin="4,0,0,0"
                        Background="#D40000" BorderBrush="#D40000"
                        Click="BtnSearchClose_Click"/>
                <TextBlock x:Name="TxtSearchStatus" Text="" Foreground="#808080" 
                           FontSize="11" VerticalAlignment="Center" Margin="8,0,0,0"/>
            </StackPanel>
        </Border>

        <!-- Toolbar: Word Wrap toggle + Donate -->
        <Border Grid.Row="1" Background="#252526" BorderBrush="#3E3E42" BorderThickness="0,0,0,1" Padding="12,6">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <TextBlock Text="📝 Word Wrap:" Foreground="#E0E0E0" FontSize="12" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <ToggleButton x:Name="ToggleWordWrap" Content="ON"
                              Style="{StaticResource ToggleWordWrapStyle}"
                              Padding="16,4" FontSize="12"
                              IsChecked="True" Click="ToggleWordWrap_Click"
                              Margin="0,0,12,0"/>
                <Button x:Name="BtnDonateToolbar" Content="💛 Donate"
                        Style="{StaticResource DonateButtonStyle}"
                        Padding="16,4" FontSize="12"
                        Click="BtnDonate_Click"/>
                <Button x:Name="BtnUpdateLatestVersion" Content="⬇️ Update latest version"
                        Style="{StaticResource AccentButtonStyle}"
                        Padding="16,4" FontSize="12"
                        Margin="12,0,0,0"
                        Click="BtnUpdateLatestVersion_Click"/>
            </StackPanel>
        </Border>

        <TabControl x:Name="MainTabControl" Grid.Row="2" Background="#1E1E1E" BorderBrush="#3E3E42" BorderThickness="1">
            <!-- Tab 1: Hardware Info -->
            <TabItem Header="🖥️ Hardware info">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- PANEL 1: GPU -->
                    <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource PanelBorderStyle}"
                            Background="#1B2638" BorderBrush="#2E4B73">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Label Grid.Row="0" Content="🎮 GPU" Style="{StaticResource SectionLabelStyle}" FontSize="16"/>

                            <TextBox x:Name="TxtGpuInfo" Grid.Row="1"
                                     Style="{StaticResource DarkTextBoxStyle}"
                                     Background="#121C2C" BorderBrush="#314E78"
                                     IsReadOnly="True" FontSize="16"
                                     PreviewMouseWheel="TextBox_PreviewMouseWheel"/>

                            <Button x:Name="BtnCopyGpu" Grid.Row="2" Content="📋 Sao chép GPU"
                                    Style="{StaticResource AccentButtonStyle}"
                                    HorizontalAlignment="Right" Margin="0,8,0,0"
                                    Click="BtnCopyGpu_Click"/>
                        </Grid>
                    </Border>

                    <!-- PANEL 2: CPU -->
                    <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource PanelBorderStyle}"
                            Background="#2B1F33" BorderBrush="#5A3E72">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="263*"/>
                                <ColumnDefinition Width="200*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Label Grid.Row="0" Content="🔧 CPU" Style="{StaticResource SectionLabelStyle}" FontSize="16" Grid.ColumnSpan="2"/>

                            <TextBox x:Name="TxtCpuInfo" Grid.Row="1"
                                     Style="{StaticResource DarkTextBoxStyle}"
                                     Background="#1D1524" BorderBrush="#64457E"
                                     IsReadOnly="True" FontSize="16"
                                     PreviewMouseWheel="TextBox_PreviewMouseWheel" Grid.ColumnSpan="2" Margin="0,0,0,39" Grid.RowSpan="2"/>

                            <Button x:Name="BtnCopyCpu" Grid.Row="2" Content="📋 Sao chép CPU"
                                    Style="{StaticResource AccentButtonStyle}"
                                    HorizontalAlignment="Right" Margin="0,8,0,0"
                                    Click="BtnCopyCpu_Click" Grid.Column="1"/>
                        </Grid>
                    </Border>

                    <!-- PANEL 3: RAM -->
                    <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource PanelBorderStyle}"
                            Background="#1C2A24" BorderBrush="#3C6D59">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Label Grid.Row="0" Content="💾 RAM" Style="{StaticResource SectionLabelStyle}" FontSize="16"/>

                            <TextBox x:Name="TxtRamInfo" Grid.Row="1"
                                     Style="{StaticResource DarkTextBoxStyle}"
                                     Background="#121C18" BorderBrush="#426F5C"
                                     IsReadOnly="True" FontSize="16"
                                     PreviewMouseWheel="TextBox_PreviewMouseWheel"/>

                            <Button x:Name="BtnCopyRam" Grid.Row="2" Content="📋 Sao chép RAM"
                                    Style="{StaticResource AccentButtonStyle}"
                                    HorizontalAlignment="Right" Margin="0,8,0,0"
                                    Click="BtnCopyRam_Click"/>
                        </Grid>
                    </Border>

                    <!-- PANEL 4: Mainboard -->
                    <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource PanelBorderStyle}"
                            Background="#332316" BorderBrush="#7A5633">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Label Grid.Row="0" Content="🔌 Bo Mạch Chủ" Style="{StaticResource SectionLabelStyle}" FontSize="16"/>

                            <TextBox x:Name="TxtMainboardInfo" Grid.Row="1"
                                     Style="{StaticResource DarkTextBoxStyle}"
                                     Background="#24180F" BorderBrush="#7F5A38"
                                     IsReadOnly="True" FontSize="16"
                                     PreviewMouseWheel="TextBox_PreviewMouseWheel"/>

                            <Button x:Name="BtnCopyMainboard" Grid.Row="2" Content="📋 Sao chép Bo Mạch Chủ"
                                    Style="{StaticResource AccentButtonStyle}"
                                    HorizontalAlignment="Right" Margin="0,8,0,0"
                                    Click="BtnCopyMainboard_Click"/>
                        </Grid>
                    </Border>

                    <!-- Footer: Author info -->
                    <Border Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                            Background="#1A1A1A" BorderBrush="#3E3E42" BorderThickness="0,1,0,0"
                            Padding="12,8">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="Tác giả: " Foreground="#808080" FontSize="12"/>
                            <TextBlock Text="Ma Minh Toàn 1993" Foreground="#0078D4" FontSize="12" FontWeight="SemiBold"/>
                            <TextBlock Text="  |  " Foreground="#505050" FontSize="12"/>
                            <TextBlock Text="Hardware info GMTPC" Foreground="#808080" FontSize="12"/>
                            <TextBlock Text="  |  " Foreground="#505050" FontSize="12"/>
                            <TextBlock Text="Xem thông tin phần cứng và loại GPU đang dùng" Foreground="#808080" FontSize="12"/>
                        </StackPanel>
                    </Border>

                    <!-- Toast Notification -->
                    <Border x:Name="ToastBorderHardware" Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2"
                            HorizontalAlignment="Center" VerticalAlignment="Top"
                            Visibility="Collapsed" Style="{StaticResource ToastBorderStyle}"
                            Margin="0,20,0,0" MinWidth="300" MaxWidth="500">
                        <TextBlock x:Name="ToastTextHardware" Text="" Foreground="#FFFFFF" FontSize="14"
                                   TextAlignment="Center" TextWrapping="Wrap"/>
                    </Border>
                </Grid>
            </TabItem>

            <!-- Tab 2: Tutorials -->
            <TabItem Header="📚 Tutorials">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Style="{StaticResource PanelBorderStyle}"
                            Background="#1F2330" BorderBrush="#3F4E6A" Margin="8,4,8,2">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <DockPanel Grid.Row="0" LastChildFill="True">
                                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" Margin="0,0,10,0">
                                    <Button x:Name="BtnToggleTutorialSearch" Content="🔎 Tìm trong Tutorials"
                                            Style="{StaticResource AccentButtonStyle}"
                                            Padding="10,4"
                                            FontSize="12"
                                            Margin="0,0,8,0"
                                            Click="BtnToggleTutorialSearch_Click"/>
                                    <Button x:Name="BtnRefreshTutorials" Content="🔄 Tải lại từ Tutorials"
                                            Style="{StaticResource AccentButtonStyle}"
                                            Padding="10,4"
                                            FontSize="12"
                                            Click="BtnRefreshTutorials_Click"/>
                                </StackPanel>
                                <StackPanel>
                                    <TextBlock Text="Tutorials"
                                               Foreground="#FFFFFF"
                                               FontSize="15"
                                               FontWeight="SemiBold"/>
                                    <TextBlock x:Name="TxtTutorialsStatus"
                                               Text="Đang chuẩn bị tải nội dung từ Tutorials..."
                                               Foreground="#A9B7D0"
                                               FontSize="10"
                                               Margin="0,1,0,0"/>
                                </StackPanel>
                            </DockPanel>

                            <Border x:Name="TutorialSearchPanel"
                                    Grid.Row="1"
                                    Background="#151C28"
                                    BorderBrush="#324257"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="8"
                                    Margin="0,6,0,0"
                                    Visibility="Collapsed">
                                <WrapPanel>
                                    <TextBlock Text="Find:"
                                               Foreground="#E0E0E0"
                                               FontSize="10"
                                               VerticalAlignment="Center"
                                               Margin="0,0,6,0"/>
                                    <TextBox x:Name="TxtTutorialSearchBox"
                                             Width="220"
                                             Height="24"
                                             FontSize="11"
                                             Background="#2D2D2D"
                                             Foreground="#E0E0E0"
                                             BorderBrush="#4A5C74"
                                             BorderThickness="1"
                                             Padding="6,2"
                                             TextChanged="TxtTutorialSearchBox_TextChanged"
                                             KeyDown="TxtTutorialSearchBox_KeyDown"/>
                                    <Button x:Name="BtnTutorialSearchPrev"
                                            Content="◀ Previous"
                                            Style="{StaticResource AccentButtonStyle}"
                                            Padding="7,2"
