                                    <TextBlock Text="  |  " Foreground="#505050" FontSize="12"/>
                                    <TextBlock Text="Karaoke Sync GMTPC" Foreground="#808080" FontSize="12"/>
                                    <TextBlock Text="  |  " Foreground="#505050" FontSize="12"/>
                                    <TextBlock Text="Đồng bộ time code phụ đề karaoke" Foreground="#808080" FontSize="12"/>
                                </StackPanel>
                            </Border>

                            <!-- Toast Notification -->
                            <Border x:Name="ToastBorderSync" Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2"
                                    HorizontalAlignment="Center" VerticalAlignment="Top"
                                    Visibility="Collapsed" Style="{StaticResource ToastBorderStyle}"
                                    Margin="0,20,0,0" MinWidth="300" MaxWidth="500">
                                <TextBlock x:Name="ToastTextSync" Text="" Foreground="#FFFFFF" FontSize="14"
                                           TextAlignment="Center" TextWrapping="Wrap"/>
                            </Border>
                        </Grid>
                    </TabItem>

                    <!-- Sub-tab: Effect -->
                    <TabItem Header="✨ Effect">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="280"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- PANEL 1: Input Subtitle -->
                            <Border Grid.Row="0" Grid.Column="0" Grid.RowSpan="2" Style="{StaticResource PanelBorderStyle}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <StackPanel Grid.Row="0" Orientation="Horizontal">
                                        <Label Content="📄 Input Subtitle" Style="{StaticResource SectionLabelStyle}"/>
                                        <TextBlock x:Name="TxtEffectLineCount" Text="" Foreground="#808080" FontSize="11"
                                                   VerticalAlignment="Center" Margin="8,0,0,0"/>
                                    </StackPanel>

                                    <TextBox x:Name="TxtEffectInput" Grid.Row="1"
                                             Style="{StaticResource DarkTextBoxStyle}"
                                             TextChanged="TxtEffectInput_TextChanged"/>
                                </Grid>
                            </Border>

                            <!-- PANEL 2: Effect Groups + Config -->
                            <Border Grid.Row="0" Grid.Column="1" Grid.RowSpan="2"
                                    Background="#252526" BorderBrush="#3E3E42" BorderThickness="1"
                                    CornerRadius="6" Padding="8" Margin="6">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                                        <Label Content="🎨 Effect Groups"
                                               Style="{StaticResource SectionLabelStyle}"
                                               Padding="4,2"/>
                                        <Button x:Name="BtnColorPicker" Content="🎨 Chọn màu"
                                                Style="{StaticResource AccentButtonStyle}"
                                                Padding="10,3" FontSize="11" Margin="8,0,0,0"
                                                Click="BtnColorPicker_Click"/>
                                    </StackPanel>

                                    <!-- Effect Groups Scrollable List -->
                                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                                                  HorizontalScrollBarVisibility="Disabled"
                                                   Margin="0,0,4,4" MaxHeight="350">
                                        <StackPanel x:Name="EffectGroupsPanel" Orientation="Vertical">

                                            <!-- Group: Position & Movement -->
                                            <Expander Header="📍 Position &amp; Movement"
                                                      Background="#2D2D30" Foreground="#E0E0E0"
                                                      BorderBrush="#3E3E42" Margin="0,2"
                                                      FontSize="12" FontWeight="SemiBold">
                                                <StackPanel Margin="4,4,4,8" Orientation="Vertical">
                                                    <Button x:Name="BtnEffectPosition" Content="\pos(x,y) - Đặt vị trí"
                                                            Style="{StaticResource AccentButtonStyle}"
                                                            Padding="8,4" FontSize="11" Margin="0,2"
                                                            HorizontalContentAlignment="Left"
                                                            Click="BtnEffectPosition_Click"/>
                                                    <Button x:Name="BtnEffectMove" Content="\move - Di chuyển"
                                                            Style="{StaticResource AccentButtonStyle}"
                                                            Padding="8,4" FontSize="11" Margin="0,2"
                                                            HorizontalContentAlignment="Left"
                                                            Click="BtnEffectMove_Click"/>
                                                    <Button x:Name="BtnEffectAlign" Content="\an - Căn lề (1-9)"
                                                            Style="{StaticResource AccentButtonStyle}"
                                                            Padding="8,4" FontSize="11" Margin="0,2"
                                                            HorizontalContentAlignment="Left"
                                                            Click="BtnEffectAlign_Click"/>
                                                    <Button x:Name="BtnEffectOrigin" Content="\org - Dời tâm xoay"
                                                            Style="{StaticResource AccentButtonStyle}"
                                                            Padding="8,4" FontSize="11" Margin="0,2"
                                                            HorizontalContentAlignment="Left"
                                                            Click="BtnEffectOrigin_Click"/>
                                                </StackPanel>
                                            </Expander>

                                            <!-- Group: Transform & Rotation -->
                                            <Expander Header="🔄 Transform &amp; Rotation"
                                                      Background="#2D2D30" Foreground="#E0E0E0"
                                                      BorderBrush="#3E3E42" Margin="0,2"
                                                      FontSize="12" FontWeight="SemiBold">
                                                <StackPanel Margin="4,4,4,8" Orientation="Vertical">
                                                    <Button x:Name="BtnEffectRotZ" Content="\frz - Xoay trục Z"
                                                            Style="{StaticResource AccentButtonStyle}"
                                                            Padding="8,4" FontSize="11" Margin="0,2"
                                                            HorizontalContentAlignment="Left"
                                                            Click="BtnEffectRotZ_Click"/>
                                                    <Button x:Name="BtnEffectRotX" Content="\frx - Lật trục X"
                                                            Style="{StaticResource AccentButtonStyle}"
                                                            Padding="8,4" FontSize="11" Margin="0,2"
                                                            HorizontalContentAlignment="Left"
                                                            Click="BtnEffectRotX_Click"/>
                                                    <Button x:Name="BtnEffectRotY" Content="\fry - Lật trục Y"
                                                            Style="{StaticResource AccentButtonStyle}"
                                                            Padding="8,4" FontSize="11" Margin="0,2"
                                                            HorizontalContentAlignment="Left"
                                                            Click="BtnEffectRotY_Click"/>
                                                    <Button x:Name="BtnEffectScaleX" Content="\fscx - Co giãn X (%)"
                                                            Style="{StaticResource AccentButtonStyle}"
                                                            Padding="8,4" FontSize="11" Margin="0,2"
                                                            HorizontalContentAlignment="Left"
                                                            Click="BtnEffectScaleX_Click"/>
                                                    <Button x:Name="BtnEffectScaleY" Content="\fscy - Co giãn Y (%)"
                                                            Style="{StaticResource AccentButtonStyle}"
                                                            Padding="8,4" FontSize="11" Margin="0,2"
                                                            HorizontalContentAlignment="Left"
                                                            Click="BtnEffectScaleY_Click"/>
                                                    <Button x:Name="BtnEffectShearX" Content="\fax - Nghiêng X"
                                                            Style="{StaticResource AccentButtonStyle}"
                                                            Padding="8,4" FontSize="11" Margin="0,2"
                                                            HorizontalContentAlignment="Left"
                                                            Click="BtnEffectShearX_Click"/>
                                                    <Button x:Name="BtnEffectShearY" Content="\fay - Nghiêng Y"
                                                            Style="{StaticResource AccentButtonStyle}"
                                                            Padding="8,4" FontSize="11" Margin="0,2"
                                                            HorizontalContentAlignment="Left"
                                                            Click="BtnEffectShearY_Click"/>
                                                </StackPanel>
                                            </Expander>

                                            <!-- Group: Font & Style -->
                                            <Expander Header="🔤 Font &amp; Style"
                                                      Background="#2D2D30" Foreground="#E0E0E0"
                                                      BorderBrush="#3E3E42" Margin="0,2"
                                                      FontSize="12" FontWeight="SemiBold">
                                                <StackPanel Margin="4,4,4,8" Orientation="Vertical">
                                                    <Button x:Name="BtnEffectFontName" Content="\fn - Đổi font chữ"
                                                            Style="{StaticResource AccentButtonStyle}"
                                                            Padding="8,4" FontSize="11" Margin="0,2"
                                                            HorizontalContentAlignment="Left"
                                                            Click="BtnEffectFontName_Click"/>
                                                    <Button x:Name="BtnEffectFontSize" Content="\fs - Cỡ chữ"
                                                            Style="{StaticResource AccentButtonStyle}"
                                                            Padding="8,4" FontSize="11" Margin="0,2"
                                                            HorizontalContentAlignment="Left"
                                                            Click="BtnEffectFontSize_Click"/>
                                                    <Button x:Name="BtnEffectBold" Content="\b - In đậm"
                                                            Style="{StaticResource AccentButtonStyle}"
                                                            Padding="8,4" FontSize="11" Margin="0,2"
                                                            HorizontalContentAlignment="Left"
                                                            Click="BtnEffectBold_Click"/>
                                                    <Button x:Name="BtnEffectItalic" Content="\i - In nghiêng"
                                                            Style="{StaticResource AccentButtonStyle}"
                                                            Padding="8,4" FontSize="11" Margin="0,2"
                                                            HorizontalContentAlignment="Left"
                                                            Click="BtnEffectItalic_Click"/>
                                                    <Button x:Name="BtnEffectUnderline" Content="\u - Gạch chân"
                                                            Style="{StaticResource AccentButtonStyle}"
                                                            Padding="8,4" FontSize="11" Margin="0,2"
                                                            HorizontalContentAlignment="Left"
                                                            Click="BtnEffectUnderline_Click"/>
                                                    <Button x:Name="BtnEffectStrikeout" Content="\s - Gạch ngang"
                                                            Style="{StaticResource AccentButtonStyle}"
                                                            Padding="8,4" FontSize="11" Margin="0,2"
                                                            HorizontalContentAlignment="Left"
                                                            Click="BtnEffectStrikeout_Click"/>
                                                </StackPanel>
                                            </Expander>

                                            <!-- Group: Border & Shadow -->
                                            <Expander Header="🌑 Border &amp; Shadow"
                                                      Background="#2D2D30" Foreground="#E0E0E0"
                                                      BorderBrush="#3E3E42" Margin="0,2"
                                                      FontSize="12" FontWeight="SemiBold">
                                                <StackPanel Margin="4,4,4,8" Orientation="Vertical">
                                                    <Button x:Name="BtnEffectBorder" Content="\bord - Viền chữ"
                                                            Style="{StaticResource AccentButtonStyle}"
                                                            Padding="8,4" FontSize="11" Margin="0,2"
                                                            HorizontalContentAlignment="Left"
                                                            Click="BtnEffectBorder_Click"/>
                                                    <Button x:Name="BtnEffectShadow" Content="\shad - Đổ bóng"
                                                            Style="{StaticResource AccentButtonStyle}"
                                                            Padding="8,4" FontSize="11" Margin="0,2"
                                                            HorizontalContentAlignment="Left"
                                                            Click="BtnEffectShadow_Click"/>
                                                    <Button x:Name="BtnEffectBlur" Content="\blur - Làm mờ viền"
                                                            Style="{StaticResource AccentButtonStyle}"
                                                            Padding="8,4" FontSize="11" Margin="0,2"
                                                            HorizontalContentAlignment="Left"
                                                            Click="BtnEffectBlur_Click"/>
                                                    <Button x:Name="BtnEffectEdgeBlur" Content="\be - Mờ cạnh"
                                                            Style="{StaticResource AccentButtonStyle}"
                                                            Padding="8,4" FontSize="11" Margin="0,2"
                                                            HorizontalContentAlignment="Left"
                                                            Click="BtnEffectEdgeBlur_Click"/>
                                                </StackPanel>
                                            </Expander>

                                            <!-- Group: Fade & Animation -->
                                            <Expander Header="⏱️ Fade &amp; Animation"
                                                      Background="#2D2D30" Foreground="#E0E0E0"
                                                      BorderBrush="#3E3E42" Margin="0,2"
                                                      FontSize="12" FontWeight="SemiBold">
                                                <StackPanel Margin="4,4,4,8" Orientation="Vertical">
                                                    <Button x:Name="BtnEffectFade" Content="\fad - Mờ dần vào/ra"
                                                            Style="{StaticResource AccentButtonStyle}"
                                                            Padding="8,4" FontSize="11" Margin="0,2"
                                                            HorizontalContentAlignment="Left"
                                                            Click="BtnEffectFade_Click"/>
                                                    <Button x:Name="BtnEffectKaraokeK" Content="\k - Karaoke từ"
                                                            Style="{StaticResource AccentButtonStyle}"
                                                            Padding="8,4" FontSize="11" Margin="0,2"
                                                            HorizontalContentAlignment="Left"
                                                            Click="BtnEffectKaraokeK_Click"/>
                                                    <Button x:Name="BtnEffectKaraokeKF" Content="\kf - Karaoke quét màu"
                                                            Style="{StaticResource AccentButtonStyle}"
                                                            Padding="8,4" FontSize="11" Margin="0,2"
                                                            HorizontalContentAlignment="Left"
                                                            Click="BtnEffectKaraokeKF_Click"/>
                                                    <Button x:Name="BtnEffectKaraokeKO" Content="\ko - Karaoke xóa viền"
                                                            Style="{StaticResource AccentButtonStyle}"
                                                            Padding="8,4" FontSize="11" Margin="0,2"
                                                            HorizontalContentAlignment="Left"
                                                            Click="BtnEffectKaraokeKO_Click"/>
                                                </StackPanel>
                                            </Expander>

                                            <!-- Group: Presets -->
                                            <Expander Header="⭐ Presets"
                                                      Background="#2D2D30" Foreground="#E0E0E0"
                                                      BorderBrush="#3E3E42" Margin="0,2"
                                                      FontSize="12" FontWeight="SemiBold">
                                                <StackPanel Margin="4,4,4,8" Orientation="Vertical">
                                                    <Button x:Name="BtnPresetFadeIn" Content="Fade In"
                                                            Style="{StaticResource AccentButtonStyle}"
                                                            Padding="8,4" FontSize="11" Margin="0,2"
                                                            HorizontalContentAlignment="Left"
                                                            Click="BtnPresetFadeIn_Click"/>
                                                    <Button x:Name="BtnPresetFadeOut" Content="Fade Out"
                                                            Style="{StaticResource AccentButtonStyle}"
                                                            Padding="8,4" FontSize="11" Margin="0,2"
                                                            HorizontalContentAlignment="Left"
                                                            Click="BtnPresetFadeOut_Click"/>
                                                    <Button x:Name="BtnPresetGlow" Content="Glow (Viền sáng)"
                                                            Style="{StaticResource AccentButtonStyle}"
                                                            Padding="8,4" FontSize="11" Margin="0,2"
                                                            HorizontalContentAlignment="Left"
                                                            Click="BtnPresetGlow_Click"/>
                                                    <Button x:Name="BtnPresetBigText" Content="Big Text (To + Đậm)"
                                                            Style="{StaticResource AccentButtonStyle}"
                                                            Padding="8,4" FontSize="11" Margin="0,2"
                                                            HorizontalContentAlignment="Left"
                                                            Click="BtnPresetBigText_Click"/>
                                                    <Button x:Name="BtnPresetCenterTop" Content="Center Top"
                                                            Style="{StaticResource AccentButtonStyle}"
                                                            Padding="8,4" FontSize="11" Margin="0,2"
                                                            HorizontalContentAlignment="Left"
                                                            Click="BtnPresetCenterTop_Click"/>
                                                    <Button x:Name="BtnPresetCenterScreen" Content="Center Screen"
                                                            Style="{StaticResource AccentButtonStyle}"
                                                            Padding="8,4" FontSize="11" Margin="0,2"
                                                            HorizontalContentAlignment="Left"
                                                            Click="BtnPresetCenterScreen_Click"/>
                                                </StackPanel>
                                            </Expander>

                                        </StackPanel>
                                    </ScrollViewer>

                                    <!-- Config Panel (shows when effect selected) -->
                                    <Border Grid.Row="2" x:Name="EffectConfigBorder"
                                            Background="#1E1E1E" BorderBrush="#0078D4" BorderThickness="1"
                                            CornerRadius="4" Padding="8" Margin="0,8,0,0"
                                            Visibility="Collapsed">
                                        <StackPanel Orientation="Vertical">
                                            <TextBlock x:Name="EffectConfigTitle" Text="Configure Effect"
                                                       Foreground="#FFFFFF" FontSize="13" FontWeight="SemiBold"
                                                       Margin="0,0,0,8"/>
                                            <StackPanel x:Name="EffectConfigFields" Orientation="Vertical" Margin="0,0,0,8"/>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                                <Button x:Name="BtnEffectApply" Content="✅ Apply"
                                                        Style="{StaticResource AccentButtonStyle}"
                                                        Padding="12,4" FontSize="11" Margin="0,0,4,0"
                                                        Click="BtnEffectApply_Click"/>
                                                <Button x:Name="BtnEffectApplyAll" Content="📋 Apply All"
                                                        Style="{StaticResource AccentButtonStyle}"
                                                        Padding="12,4" FontSize="11" Margin="0,0,4,0"
                                                        Click="BtnEffectApplyAll_Click"/>
                                                <Button x:Name="BtnEffectCancel" Content="❌"
                                                        Style="{StaticResource AccentButtonStyle}"
                                                        Padding="8,4" FontSize="11"
                                                        Background="#505050" BorderBrush="#505050"
                                                        Click="BtnEffectCancel_Click"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </Border>

                            <!-- PANEL 3: Effect Output -->
                            <Border Grid.Row="0" Grid.Column="2" Grid.RowSpan="2" Style="{StaticResource PanelBorderStyle}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <Label Grid.Row="0" Content="✨ Output" Style="{StaticResource SectionLabelStyle}"/>

                                    <TextBox x:Name="TxtEffectOutput" Grid.Row="1"
                                             Style="{StaticResource DarkTextBoxStyle}"
                                             IsReadOnly="True" FontSize="14"
                                             PreviewMouseWheel="TextBox_PreviewMouseWheel"/>

                                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                                        <Button x:Name="BtnCopyEffect" Content="📋 Copy"
                                                Style="{StaticResource AccentButtonStyle}"
                                                Padding="12,4" FontSize="11" Margin="0,0,8,0"
                                                Click="BtnCopyEffect_Click"/>
                                        <Button x:Name="BtnClearEffect" Content="🗑️ Clear Effects" Style="{StaticResource AccentButtonStyle}" Padding="12,4" FontSize="11" Margin="0,0,8,0" Click="BtnClearEffect_Click"/>
                                        <Button x:Name="BtnResetEffect" Content="🔄 Reset"
                                                Style="{StaticResource AccentButtonStyle}"
                                                Padding="12,4" FontSize="11"
                                                Click="BtnResetEffect_Click"/>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- Footer: Author info -->
                            <Border Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3"
                                    Background="#1A1A1A" BorderBrush="#3E3E42" BorderThickness="0,1,0,0"
                                    Padding="12,8">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <TextBlock Text="Tác giả: " Foreground="#808080" FontSize="12"/>
                                    <TextBlock Text="Ma Minh Toàn 1993" Foreground="#0078D4" FontSize="12" FontWeight="SemiBold"/>
                                    <TextBlock Text="  |  " Foreground="#505050" FontSize="12"/>
                                    <TextBlock Text="Effect GMTPC" Foreground="#808080" FontSize="12"/>
                                    <TextBlock Text="  |  " Foreground="#505050" FontSize="12"/>
                                    <TextBlock Text="Tạo hiệu ứng ASS Override Tags" Foreground="#808080" FontSize="12"/>
                                </StackPanel>
                            </Border>

                            <!-- Toast Notification -->
                            <Border x:Name="ToastBorderEffect" Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3"
                                    HorizontalAlignment="Center" VerticalAlignment="Top"
                                    Visibility="Collapsed" Style="{StaticResource ToastBorderStyle}"
                                    Margin="0,20,0,0" MinWidth="300" MaxWidth="500">
                                <TextBlock x:Name="ToastTextEffect" Text="" Foreground="#FFFFFF" FontSize="14"
                                           TextAlignment="Center" TextWrapping="Wrap"/>
                            </Border>
                        </Grid>
                    </TabItem>
                </TabControl>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
