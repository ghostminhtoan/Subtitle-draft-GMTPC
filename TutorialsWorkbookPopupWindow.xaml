<Window x:Class="Subtitle_draft_GMTPC.TutorialsWorkbookPopupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Shortcuts Excel"
        Width="1320"
        Height="860"
        WindowStartupLocation="CenterOwner"
        Background="#1E1E1E"
        Foreground="#E0E0E0"
        Loaded="Window_Loaded"
        Closed="Window_Closed">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#1F2330" BorderBrush="#3F4E6A" BorderThickness="1" CornerRadius="6" Padding="10">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Shortcuts Excel"
                           Foreground="#FFFFFF"
                           FontSize="16"
                           FontWeight="SemiBold"/>
                <TextBlock x:Name="TxtStatus"
                           Text="Đang chuẩn bị mở workbook OneDrive..."
                           Foreground="#A9B7D0"
                           FontSize="11"
                           Margin="12,2,0,0"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Margin="0,10,0,10" Background="#1A1A1A" BorderBrush="#3E3E42" BorderThickness="1" CornerRadius="6">
            <WebBrowser x:Name="ExcelBrowser"
                        Navigating="ExcelBrowser_Navigating"
                        LoadCompleted="ExcelBrowser_LoadCompleted"/>
        </Border>

        <Border Grid.Row="2" Background="#171717" BorderBrush="#30363d" BorderThickness="1" CornerRadius="6" Padding="10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <TextBlock x:Name="TxtFooter"
                           Text="Workbook hiển thị bằng browser tích hợp, không cần WebView2."
                           Foreground="#808080"
                           FontSize="11"
                           VerticalAlignment="Center"/>
                <Button x:Name="BtnOpenExternalBrowser"
                        Content="Mở bằng trình duyệt mặc định"
                        Style="{StaticResource AccentButtonStyle}"
                        Padding="12,4"
                        FontSize="11"
                        Margin="12,0,0,0"
                        Click="BtnOpenExternalBrowser_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
