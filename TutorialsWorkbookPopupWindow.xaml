<Window x:Class="Subtitle_draft_GMTPC.TutorialsWorkbookPopupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Shortcuts Excel"
        Width="1320"
        Height="860"
        WindowStartupLocation="CenterOwner"
        Background="#1E1E1E"
        Foreground="#E0E0E0"
        Loaded="Window_Loaded"
        Closed="Window_Closed">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#1F2330" BorderBrush="#3F4E6A" BorderThickness="1" CornerRadius="6" Padding="12">
            <StackPanel>
                <TextBlock Text="Shortcuts Excel"
                           Foreground="#FFFFFF"
                           FontSize="18"
                           FontWeight="SemiBold"/>
                <TextBlock x:Name="TxtStatus"
                           Text="Đang tải workbook Google Sheets..."
                           Foreground="#A9B7D0"
                           FontSize="12"
                           Margin="0,6,0,0"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Margin="0,10,0,10" Background="#1A1A1A" BorderBrush="#3E3E42" BorderThickness="1" CornerRadius="6">
            <WebBrowser x:Name="WorkbookBrowser"
                        Navigating="WorkbookBrowser_Navigating"
                        LoadCompleted="WorkbookBrowser_LoadCompleted"/>
        </Border>

        <Border Grid.Row="2" Background="#171717" BorderBrush="#30363d" BorderThickness="1" CornerRadius="6" Padding="10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <TextBlock x:Name="TxtFooter"
                           Text="Ưu tiên hiển thị trực tiếp trong app; nếu lỗi sẽ mở bằng trình duyệt."
                           Foreground="#808080"
                           FontSize="11"
                           VerticalAlignment="Center"/>
                <Button x:Name="BtnOpenExternalBrowser"
                        Content="Mở bằng trình duyệt"
                        Background="#0078D4"
                        Foreground="#FFFFFF"
                        BorderThickness="0"
                        Padding="12,5"
                        FontSize="11"
                        Margin="12,0,0,0"
                        Click="BtnOpenExternalBrowser_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
