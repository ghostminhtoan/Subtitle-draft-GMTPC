<Window x:Class="Subtitle_draft_GMTPC.TutorialsWorkbookPopupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Shortcuts Excel"
        Width="820"
        Height="240"
        WindowStartupLocation="CenterOwner"
        Background="#1E1E1E"
        Foreground="#E0E0E0"
        Loaded="Window_Loaded"
        Closed="Window_Closed">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#1F2330" BorderBrush="#3F4E6A" BorderThickness="1" CornerRadius="6" Padding="12">
            <StackPanel>
                <TextBlock Text="Shortcuts Excel"
                           Foreground="#FFFFFF"
                           FontSize="18"
                           FontWeight="SemiBold"/>
                <TextBlock x:Name="TxtStatus"
                           Text="Đang mở workbook OneDrive trong trình duyệt mặc định..."
                           Foreground="#A9B7D0"
                           FontSize="12"
                           Margin="0,6,0,0"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Margin="0,12,0,12" Background="#16181d" BorderBrush="#3E3E42" BorderThickness="1" CornerRadius="6" Padding="14">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="Workbook Excel sẽ mở bằng trình duyệt mặc định của máy."
                           Foreground="#E0E0E0"
                           FontSize="13"
                           TextAlignment="Center"
                           TextWrapping="Wrap"
                           Margin="0,0,0,10"/>
                <TextBlock Text="Không cần WebView2, không cần cài thêm gì ở máy người khác."
                           Foreground="#A9B7D0"
                           FontSize="11"
                           TextAlignment="Center"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="2" Background="#171717" BorderBrush="#30363d" BorderThickness="1" CornerRadius="6" Padding="10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button x:Name="BtnOpenExternalBrowser"
                        Content="Mở workbook"
                        Background="#0078D4"
                        Foreground="#FFFFFF"
                        BorderThickness="0"
                        Padding="12,5"
                        FontSize="11"
                        Click="BtnOpenExternalBrowser_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
